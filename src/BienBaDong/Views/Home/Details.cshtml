@model BienBaDong.Models.Destination

@{
    ViewBag.Title = Model.Title;
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="mb-2">@Model.Title</h1>
            <p class="text-muted mb-4">
                <i class="fa fa-eye"></i> @Model.ViewCount lượt xem
            </p>

            <img src="@Model.ImageUrl" class="img-fluid rounded mb-4" alt="@Model.Title" style="width:100%; max-height: 500px; object-fit: cover;" />

            <div class="content" style="font-size: 1.1em; line-height: 1.8;">
                @Html.Raw(Model.FullDescription)
            </div>

            <hr class="mt-5 mb-5" />

            <h4 class="mb-4">Bình luận (@Model.Comments.Count(c => c.IsApproved))</h4>

            <div class="comments-list mb-5">
                @if (Model.Comments != null && Model.Comments.Any(c => c.IsApproved))
                {
                    foreach (var comment in Model.Comments.Where(c => c.IsApproved).OrderByDescending(c => c.CreatedDate))
                    {
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <h6 class="font-weight-bold text-primary">@comment.AuthorName</h6>
                                <p class="text-muted small mb-2">@comment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>
                                <p class="mb-0">@comment.Content</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                }
            </div>

            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="mb-3">Viết bình luận của bạn</h5>
                    @using (Html.BeginForm("AddComment", "Home", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="DestinationId" value="@Model.Id" />

                        <div class="form-group mb-3">
                            <input type="text" name="AuthorName" class="form-control" placeholder="Tên của bạn *" required />
                        </div>
                        <div class="form-group mb-3">
                            <textarea name="Content" class="form-control" rows="3" placeholder="Nội dung bình luận *" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi Bình Luận</button>
                    }
                </div>
            </div>

            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary mt-4">Quay lại trang chủ</a>
        </div>
    </div>
</div>